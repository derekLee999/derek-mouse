{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "鼠标连点器",
  "version": "0.1.0",
  "identifier": "com.derekmouse.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "鼠标连点器",
        "width": 620,
        "height": 600,
        "center": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/derek-mouse/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "opencv_world490.dll": "opencv_world490.dll",
      "MSVCP140.dll": "MSVCP140.dll",
      "VCRUNTIME140.dll": "VCRUNTIME140.dll",
      "VCRUNTIME140_1.dll": "VCRUNTIME140_1.dll",
      "CONCRT140.dll": "CONCRT140.dll"
    }
  }
}
